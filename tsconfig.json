{
  "compilerOptions": {
	"jsx": "react",
	"target": "es2015",
	"module": "esnext",
	"moduleResolution": "bundler",
	"lib": [
	  "es2020",
	  "dom"
	],
	"esModuleInterop": true,
	"forceConsistentCasingInFileNames": true,
	"strict": true,
	"skipLibCheck": true,
	"allowImportingTsExtensions": true
  }
}
